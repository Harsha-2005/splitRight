// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  groupsCreated    Group[]         @relation("GroupCreator")
  groupMemberships GroupMember[]
  expensesPaid     Expense[]       @relation("ExpensePayer")
  expenseSplits    ExpenseSplit[]
  settlementsFrom  Settlement[]    @relation("SettlementFrom")
  settlementsTo    Settlement[]    @relation("SettlementTo")
  importsCreated   ImportSession[]

  @@map("users")
}

model Group {
  id        Int      @id @default(autoincrement())
  name      String
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  creator    User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members    GroupMember[]
  expenses   Expense[]
  settlements Settlement[]
  importSessions ImportSession[]

  @@map("groups")
}

model GroupMember {
  id       Int      @id @default(autoincrement())
  groupId  Int      @map("group_id")
  userId   Int      @map("user_id")
  joinedAt DateTime @map("joined_at") @db.Date
  leftAt   DateTime? @map("left_at") @db.Date

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId, joinedAt])
  @@map("group_members")
}

model Expense {
  id           Int      @id @default(autoincrement())
  groupId      Int      @map("group_id")
  description  String
  paidBy       Int      @map("paid_by")
  amount       Decimal  @db.Decimal(12, 2)
  currency     String   @default("INR") @db.Char(3)
  exchangeRate Decimal  @default(1.0) @map("exchange_rate") @db.Decimal(10, 4)
  amountInr    Decimal  @map("amount_inr") @db.Decimal(12, 2)
  expenseDate  DateTime @map("expense_date") @db.Date
  splitType    String   @map("split_type") // equal | unequal | percentage | share
  isRefund     Boolean  @default(false) @map("is_refund")
  notes        String?
  importRow    Int?     @map("import_row")
  createdAt    DateTime @default(now()) @map("created_at")

  group  Group          @relation(fields: [groupId], references: [id])
  payer  User           @relation("ExpensePayer", fields: [paidBy], references: [id])
  splits ExpenseSplit[]

  @@map("expenses")
}

model ExpenseSplit {
  id          Int     @id @default(autoincrement())
  expenseId   Int     @map("expense_id")
  userId      Int     @map("user_id")
  shareAmount Decimal @map("share_amount") @db.Decimal(12, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("expense_splits")
}

model Settlement {
  id         Int      @id @default(autoincrement())
  groupId    Int      @map("group_id")
  fromUserId Int      @map("from_user")
  toUserId   Int      @map("to_user")
  amount     Decimal  @db.Decimal(12, 2)
  currency   String   @default("INR") @db.Char(3)
  settledAt  DateTime @map("settled_at") @db.Date
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  group    Group @relation(fields: [groupId], references: [id])
  fromUser User  @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("SettlementTo", fields: [toUserId], references: [id])

  @@map("settlements")
}

model ImportSession {
  id             Int      @id @default(autoincrement())
  groupId        Int      @map("group_id")
  filename       String?
  importedBy     Int      @map("imported_by")
  status         String   @default("pending_review") // pending_review | completed | cancelled
  totalRows      Int      @default(0) @map("total_rows")
  importedCount  Int      @default(0) @map("imported_count")
  skippedCount   Int      @default(0) @map("skipped_count")
  anomalyCount   Int      @default(0) @map("anomaly_count")
  rawData        Json?    @map("raw_data") // full parsed CSV stored for review
  createdAt      DateTime @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  group    Group           @relation(fields: [groupId], references: [id])
  importer User            @relation(fields: [importedBy], references: [id])
  anomalies ImportAnomaly[]

  @@map("import_sessions")
}

model ImportAnomaly {
  id            Int      @id @default(autoincrement())
  sessionId     Int      @map("session_id")
  rowNumber     Int      @map("row_number")
  rawData       Json     @map("raw_data")
  anomalyType   String   @map("anomaly_type")
  description   String
  severity      String   // error | warning | info
  userDecision  String   @default("pending") @map("user_decision") // approve | reject | modify | pending
  resolvedData  Json?    @map("resolved_data")
  createdAt     DateTime @default(now()) @map("created_at")

  session ImportSession @relation(fields: [sessionId], references: [id])

  @@map("import_anomalies")
}

model ExchangeRate {
  id           Int      @id @default(autoincrement())
  fromCurrency String   @map("from_currency") @db.Char(3)
  toCurrency   String   @map("to_currency") @db.Char(3)
  rateDate     DateTime @map("rate_date") @db.Date
  rate         Decimal  @db.Decimal(10, 4)

  @@unique([fromCurrency, toCurrency, rateDate])
  @@map("exchange_rates")
}
